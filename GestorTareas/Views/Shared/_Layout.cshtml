<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title GestorTareas</title>
    @Styles.Render("~/Content/css")
</head>
<body>

    <nav class="navbar navbar-inverse navbar-fixed-top">
        <div class="container">
            <div class="navbar-header">
                <a class="navbar-brand" href="@Url.Action("Index","Home")">
                    <span class="glyphicon glyphicon-tasks"></span>GestorTareas
                </a>
            </div>
            <div id="mainNav" class="collapse navbar-collapse">
                <ul class="nav navbar-nav">
                    <li class="@(ViewContext.RouteData.Values["controller"].ToString()=="Home" ? "active" : "")">
                        @Html.ActionLink("Inicio", "Index", "Home")
                    </li>
                    <li class="@(ViewContext.RouteData.Values["controller"].ToString()=="Task" && ViewContext.RouteData.Values["action"].ToString()=="Index" ? "active" : "")">
                        @Html.ActionLink("Mis Tareas", "Index", "Task")
                    </li>
                    <li class="@(ViewContext.RouteData.Values["action"].ToString()=="Create" ? "active" : "")">
                        @Html.ActionLink("Nueva Tarea", "Create", "Task")
                    </li>
                </ul>
                @if (Session["UserName"] != null)
                {
                    <ul class="nav navbar-nav navbar-right">
                        <li>
                            <a href="#" title="Usuario actual">
                                <span class="glyphicon glyphicon-user"></span>
                                @Session["UserName"]
                            </a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
                <span class="glyphicon glyphicon-ok-circle"></span>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
                <span class="glyphicon glyphicon-exclamation-sign"></span>
                @TempData["ErrorMessage"]
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Cerrar">
                    <span aria-hidden="true">&times;</span>
                </button>
                <span class="glyphicon glyphicon-warning-sign"></span>
                @TempData["WarningMessage"]
            </div>
        }

        @RenderBody()

        <hr />
        <footer class="text-center text-muted">
            <p>&copy; @DateTime.Now.Year &mdash; GestorTareas | Programacion Avanzada en Web &mdash; UNED</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script src="@Url.Content("~/Scripts/task-scripts.js")"></script>
    @RenderSection("scripts", required: false)

</body>
</html>
